# ============================================
# Environment Variables - Production
# ============================================
# Este archivo debe ser mantenido en secreto
# NO subir a repositorio público

# ============================================
# Database Configuration
# ============================================
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_NAME=scanqueue
DATABASE_USER=scanqueue
DATABASE_PASSWORD=CAMBIAR_ESTO_AHORA_123!@#
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=20

# ============================================
# Backend Configuration
# ============================================
NODE_ENV=production
PORT=5000
LOG_LEVEL=info

# ============================================
# JWT & Security
# ============================================
# Cambiar estos valores con contraseñas seguras generadas
JWT_SECRET=CAMBIAR_ESTO_JWT_SECRET_SEGURO_123!@#456
JWT_EXPIRY=7d
REFRESH_TOKEN_SECRET=CAMBIAR_ESTO_REFRESH_SECRET_123!@#456
REFRESH_TOKEN_EXPIRY=30d

# ============================================
# CORS & Frontend
# ============================================
# Cambiar a tu dominio real
CORS_ORIGIN=https://tudominio.com
FRONTEND_URL=https://tudominio.com

# ============================================
# API Configuration
# ============================================
API_URL=https://tudominio.com/api
API_TIMEOUT=30000
API_MAX_RETRIES=3

# ============================================
# Frontend Configuration
# ============================================
VITE_API_URL=https://tudominio.com/api
VITE_WS_URL=wss://tudominio.com/ws
VITE_APP_NAME=ScanQueue
VITE_APP_VERSION=1.0.0

# ============================================
# WebSocket Configuration
# ============================================
WS_ORIGIN=https://tudominio.com
WS_PATH=/socket.io
WS_TRANSPORTS=websocket,polling

# ============================================
# Rate Limiting
# ============================================
RATE_LIMIT_WINDOW=15m
RATE_LIMIT_MAX=100
RATE_LIMIT_SKIP_FAILED_REQUESTS=false
RATE_LIMIT_SKIP_SUCCESSFUL_REQUESTS=false

# ============================================
# File Upload
# ============================================
MAX_FILE_SIZE=104857600  # 100MB
UPLOAD_DIR=/app/uploads
ALLOWED_EXTENSIONS=pdf,csv,xlsx,png,jpg,jpeg,gif

# ============================================
# SMTP Configuration (Email)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=escuela@gmail.com
SMTP_PASSWORD=CAMBIAR_ESTO_SMTP_PASSWORD
SMTP_FROM_NAME=ScanQueue
SMTP_FROM_EMAIL=noreply@tudominio.com

# ============================================
# Email Templates
# ============================================
EMAIL_VERIFICATION_ENABLED=true
EMAIL_REPORTS_ENABLED=true
EMAIL_ALERTS_ENABLED=true

# ============================================
# Backup Configuration
# ============================================
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *  # 2 AM diarios
BACKUP_RETENTION_DAYS=30
BACKUP_DIR=/app/backups
BACKUP_COMPRESS=true

# ============================================
# AWS S3 (Opcional para backups remotos)
# ============================================
AWS_ENABLED=false
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=scanqueue-backups

# ============================================
# Logging
# ============================================
LOG_FORMAT=json
LOG_DIR=/app/logs
LOG_MAX_SIZE=100m
LOG_MAX_FILES=10
LOG_RETENTION_DAYS=30

# ============================================
# Monitoring & Alerting
# ============================================
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_INTERVAL=30  # segundos
ALERT_EMAIL=admin@tudominio.com
ALERT_ENABLED=true

# ============================================
# Session Configuration
# ============================================
SESSION_SECRET=CAMBIAR_ESTO_SESSION_SECRET_123!@#456
SESSION_TIMEOUT=86400  # 24 horas
SESSION_SECURE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=Strict

# ============================================
# Redis (Si se usa para cache/sessions)
# ============================================
REDIS_ENABLED=false
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ============================================
# Feature Flags
# ============================================
FEATURE_QR_SCANNER=true
FEATURE_REPORTS=true
FEATURE_ANALYTICS=true
FEATURE_BULK_UPLOAD=true
FEATURE_EMAIL_NOTIFICATIONS=true
FEATURE_WEBHOOKS=false

# ============================================
# Admin Configuration
# ============================================
ADMIN_EMAIL=admin@tudominio.com
ADMIN_PASSWORD=CAMBIAR_ESTO_ADMIN_PASSWORD_123!@#
ADMIN_NEW_PASSWORD_ON_FIRST_LOGIN=true

# ============================================
# SSL/TLS
# ============================================
SSL_ENABLED=true
SSL_CERT_PATH=/etc/nginx/certs/cert.pem
SSL_KEY_PATH=/etc/nginx/certs/key.pem
SSL_CHAIN_PATH=/etc/nginx/certs/chain.pem

# ============================================
# Timezone
# ============================================
TZ=America/Argentina/Buenos_Aires

# ============================================
# Performance
# ============================================
COMPRESSION_ENABLED=true
CACHE_ENABLED=true
CACHE_TTL=3600

# ============================================
# Debug & Development (Nunca activar en prod)
# ============================================
DEBUG=false
VERBOSE_LOGGING=false
